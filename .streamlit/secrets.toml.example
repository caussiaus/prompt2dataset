# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# The actual secrets.toml is git-ignored and never committed.
#
# Usage:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   # then edit .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────

# ── App access (optional — not wired in app.py right now) ────────────────────
# A password gate used to read APP_PASSWORD here; it was removed for local/dev UX.
# Re-enable by restoring _auth() in app.py if you need a shared team password again.
# APP_PASSWORD = "change-me-before-sharing"

# ── Cloudflare Tunnel (optional — used by start_app.sh) ─────────────────────
# CF_TUNNEL_ID = "59b0eaff-353c-4ae3-945c-3f0d5a56ff64"
